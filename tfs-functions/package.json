{
  "name": "tfs-functions",
  "version": "1.0.0",
  "description": "",
  "main": "dist/src/functions/*.js",
  "scripts": {
    "build": "tsc",
    "clean": "rimraf dist",
    "docker:build": "docker build -t tfs-functions-local .",
    "docker:start": "docker compose -f docker-compose.local.yml up --build",
    "prestart": "npm run clean && npm run build",
    "start": "func start",
    "test": "echo \"No tests yet...\"",
    "watch": "tsc -w"
  },
  "dependencies": {
    "@azure/functions": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "20.x",
    "azure-functions-core-tools": "^4.x",
    "rimraf": "^5.0.0",
    "typescript": "^5.0.0"
  }
}
